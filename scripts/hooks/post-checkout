#!/usr/bin/env bash
# Restore assets/ from data/bundled/ after branch checkout (incl. pull).
ROOT="$(git rev-parse --show-toplevel)"
bash "$ROOT/scripts/sync_bundled_data.sh" --quiet || true
if ! bash "$ROOT/scripts/verify_assets.sh" >/dev/null 2>&1; then
  echo ""
  echo "WARNING: App data under assets/ is incomplete after Git checkout."
  echo "  1) bash scripts/seed_bundled_data.sh    # once, if you have data in assets/"
  echo "  2) bash scripts/sync_bundled_data.sh    # restore assets/ from data/bundled/"
  echo "  See scripts/DATA_WORKFLOW.md"
  echo ""
fi
